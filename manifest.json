{
  "$schema": "https://developer.microsoft.com/json-schemas/office-js/v1.1/manifest.schema.json",
  "id": "00000000-0000-0000-0000-000000000001",
  "Version": "1.0.0.0",
  "ProviderName": "Doodle AG",
  "DefaultLocale": "en-US",
  "DisplayName": {
    "DefaultValue": "Doodle Scheduler"
  },
  "Description": {
    "DefaultValue": "Schedule meetings directly from Outlook using Doodle"
  },
  "IconUrl": {
    "DefaultValue": "https://localhost:3000/assets/icon-64.png"
  },
  "HighResolutionIconUrl": {
    "DefaultValue": "https://localhost:3000/assets/icon-128.png"
  },
  "SupportUrl": {
    "DefaultValue": "https://doodle.com/support"
  },
  "AppDomains": [
    "https://api.doodle.com"
  ],
  "Hosts": [
    {
      "Name": "Mailbox"
    }
  ],
  "Requirements": {
    "Sets": [
      {
        "Name": "Mailbox",
        "MinVersion": "1.5"
      }
    ]
  },
  "FormSettings": {
    "Form": {
      "xsi:type": "ItemEdit",
      "DesktopSettings": {
        "SourceLocation": "https://localhost:3000/taskpane/index.html",
        "RequestedHeight": 550
      }
    }
  },
  "Permissions": "ReadWriteItem",
  "Rule": {
    "xsi:type": "RuleCollection",
    "Mode": "Or",
    "Rule": [
      {
        "xsi:type": "ItemIs",
        "ItemType": "Message",
        "FormType": "Edit"
      }
    ]
  },
  "VersionOverrides": {
    "xsi:type": "VersionOverridesV1_1",
    "Requirements": {
      "Sets": [
        {
          "Name": "Mailbox",
          "MinVersion": "1.5"
        }
      ]
    },
    "Hosts": [
      {
        "xsi:type": "MailHost",
        "DesktopFormFactor": {
          "FunctionFile": "https://localhost:3000/commands/commands.html",
          "ExtensionPoint": {
            "xsi:type": "MessageComposeCommandSurface",
            "OfficeTab": {
              "id": "TabDefault",
              "Group": {
                "id": "msgComposeGroup",
                "Label": {
                  "DefaultValue": "Doodle"
                },
                "Icon": {
                  "bt:Image": [
                    {
                      "size": "16",
                      "resid": "Icon.16x16"
                    },
                    {
                      "size": "32",
                      "resid": "Icon.32x32"
                    },
                    {
                      "size": "80",
                      "resid": "Icon.80x80"
                    }
                  ]
                },
                "Control": {
                  "xsi:type": "Button",
                  "id": "msgComposeOpenPaneButton",
                  "Label": {
                    "DefaultValue": "Schedule"
                  },
                  "Supertip": {
                    "Title": {
                      "DefaultValue": "Doodle Scheduler"
                    },
                    "Description": {
                      "DefaultValue": "Open Doodle scheduling panel"
                    }
                  },
                  "Icon": {
                    "bt:Image": [
                      {
                        "size": "16",
                        "resid": "Icon.16x16"
                      },
                      {
                        "size": "32",
                        "resid": "Icon.32x32"
                      },
                      {
                        "size": "80",
                        "resid": "Icon.80x80"
                      }
                    ]
                  },
                  "Action": {
                    "xsi:type": "ShowTaskpane",
                    "TaskpaneId": "ButtonId1",
                    "SourceLocation": "https://localhost:3000/taskpane/index.html"
                  }
                }
              }
            }
          }
        }
      }
    ],
    "Resources": {
      "Images": [
        {
          "id": "Icon.16x16",
          "DefaultValue": "https://localhost:3000/assets/icon-16.png"
        },
        {
          "id": "Icon.32x32",
          "DefaultValue": "https://localhost:3000/assets/icon-32.png"
        },
        {
          "id": "Icon.80x80",
          "DefaultValue": "https://localhost:3000/assets/icon-80.png"
        }
      ]
    }
  }
}
